# =============================================================================
# Régua de cobrança MAG — configuração
# Copie este arquivo para `.env` e preencha. NUNCA commite o `.env`.
# =============================================================================

# --- Z-API (WhatsApp) ---------------------------------------------------------
# Painel Z-API: instância, token da instância e token de segurança da conta.
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Identidade da corretora (entra nas mensagens) ---------------------------
NOME_CORRETOR=
NOME_CORRETORA=

# Número do corretor/admin da plataforma (com DDD) para receber aviso de "sessão MAG expirou".
# Ex.: 5511999998888  (deixe vazio para desativar a notificação por WhatsApp)
NOTIFY_WHATSAPP_TO=

# FASE DE TESTE (segurança): preencha com o SEU número (ex.: 5551999998888) e
# TODO WhatsApp vai para ele, NUNCA para o do cliente. ESVAZIE para enviar de
# verdade aos clientes (produção).
WHATSAPP_OVERRIDE_TO=

# --- Agente conversacional inbound (webhook Z-API) ---------------------------
# Número do admin que recebe avisos de remarcação/dúvida (ex.: 5511999998888).
# Vazio = cai no NOTIFY_WHATSAPP_TO como fallback.
ADMIN_WHATSAPP=

# Segredo do webhook (entra no PATH: /webhook/zapi/<segredo>). Configure o MESMO
# valor na URL de webhook do painel Z-API. VAZIO = o webhook REJEITA tudo (fail-closed).
ZAPI_WEBHOOK_SECRET=

# Classificação de intenção: rule-based (offline) por padrão. Ligue o seam LLM
# (Claude) só para frases ambíguas. Precisa de ANTHROPIC_API_KEY.
USAR_LLM_INTENT=false
ANTHROPIC_API_KEY=
# Teto de dias para a data desejada numa remarcação ("pago dia X").
RESCHEDULE_MAX_DIAS=30

# --- Operação -----------------------------------------------------------------
HORARIO_INICIO=09:00
HORARIO_FIM=18:00
DIAS_UTEIS_APENAS=true
TIMEZONE=America/Sao_Paulo

# Revisão matinal do DOM: 1x/dia, a partir desta hora, SÓ se a sessão estiver de pé.
# Se um seletor crítico quebrar (MAG mudou o layout), avisa por WhatsApp (NOTIFY_WHATSAPP_TO).
HEALTHCHECK_AUTO=true
HEALTHCHECK_HORA=08:00

# Anti-ban WhatsApp (número estabelecido). Pacing aleatório entre envios.
MAX_WHATSAPP_POR_DIA=70
PACING_MIN_S=20
PACING_MAX_S=45
MAX_SENDS_PER_RUN=200

# Disjuntor: aborta o lote de WhatsApp após N falhas consecutivas.
MAX_FALHAS_CONSECUTIVAS=5

# --- Armazenamento / sessão ---------------------------------------------------
DB_PATH=./regua.sqlite
PLAYWRIGHT_USER_DATA_DIR=./.mag_session

# Identificador local do corretor (multi-tenant futuro). Qualquer string estável.
CORRETOR_ID=local

# Senha do painel web (--dashboard). Vazio = login provisório (qualquer senha entra).
DASHBOARD_PASSWORD=

# --- URLs da plataforma MAG ---------------------------------------------------
MAG_LOGIN_URL=https://plataformadosprodutores.mag.com.br/s/login/
MAG_INADIMPLENCIAS_URL=https://plataformadosprodutores.mag.com.br/s/inadimplencias?orderBy=Inadimplencia_Data_Vencimento__c&typeOrderBy=DESC&cliente=naoTrabalhado&cliente=trabalhadoParcialmente
MAG_CLIENTES_URL=https://plataformadosprodutores.mag.com.br/s/clientes?status=ativo&tipoCliente=VI&page=1&pageSize=10&orderBy=premioVI&typeOrderBy=DESC

# --- Limitação conhecida ------------------------------------------------------
# Expiração do link de pagamento MAG é desconhecida. Se descobrir, preencha o
# número de dias para que o e-mail do dia 2 regenere o link quando estiver velho.
PAYMENT_LINK_TTL_DAYS=

# --- Multi-seguradora ---------------------------------------------------------
# Seguradora padrão do CLI (mag | prudential). O dashboard hospeda as duas e a
# pessoa escolhe na tela de login — esta var só afeta o CLI sem --insurer.
INSURER=mag

# --- Prudential (Life Planner AEM + relatório ASPX) ---------------------------
# Conector implementado; PENDENTE de calibração ao vivo do DOM (form/grade estão
# num iframe cross-origin). Fluxo: --insurer prudential --login -> --inspect ->
# calibrar seguros/connectors/prudential/selectors.yaml -> meta.calibrated: true.
# As URLs têm defaults conhecidos; só preencha se mudarem.
PRUDENTIAL_LOGIN_URL=
PRUDENTIAL_ATRASO_URL=
# Dias de atraso mínimos no filtro do "Relatório de Atraso" (1 = pega todos).
PRUDENTIAL_DIAS_ATRASO_MIN=1
